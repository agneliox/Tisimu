<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        app:elevation="0dp">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsingToolbarLayout"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:fitsSystemWindows="true"
            app:contentScrim="?attr/colorSurface"
            app:expandedTitleMarginStart="72dp"
            app:expandedTitleMarginBottom="16dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed"
            app:toolbarId="@+id/communityDetailToolbar"
            app:titleEnabled="false">

            <!-- Community Banner Image / Cover -->
            <ImageView
                android:id="@+id/ivCommunityCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                app:layout_collapseMode="parallax"
                app:layout_collapseParallaxMultiplier="0.7" />

            <!-- Gradient Overlay for better text visibility -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax"

                />
<!--                tools:src="@tools:sample/backgrounds/scenic"-->
<!--            android:background="@drawable/gradient_overlay"-->

            <!-- Community Avatar (Circular) -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivCommunityAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="@string/community_avatar"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Circle"
                app:layout_collapseMode="parallax"
                tools:src="@tools:sample/avatars"
                android:elevation="4dp" />


            <!-- Community Name (Expanded) -->
            <TextView
                android:id="@+id/tvCommunityNameExpanded"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="120dp"
                android:layout_marginBottom="24dp"
                android:text="@string/community_name"
                android:textSize="20sp"
                android:textStyle="bold"
                android:shadowColor="@android:color/black"
                android:shadowRadius="4"
                android:elevation="4dp"
                app:layout_collapseMode="parallax"
                android:visibility="visible" />

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/communityDetailToolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"

                android:theme="@style/ThemeOverlay.Material3.ActionBar"
                app:navigationIcon="@drawable/ic_back"
                app:navigationIconTint="?attr/colorOnSurface"
                app:titleTextColor="?attr/colorOnSurface"
                app:layout_collapseMode="pin"
                app:title=""
                app:menu="@menu/community_detail_menu" />

        </com.google.android.material.appbar.CollapsingToolbarLayout>

        <!-- Community Stats Chip Group (Collapsed) -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:layout_collapseMode="none"
            android:visibility="gone">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipMemberCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 members"
                app:chipIcon="@drawable/ic_people"
                app:chipIconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipVisibility"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Public"
                app:chipIcon="@drawable/ic_public"
                app:chipIconTint="?attr/colorOnSurfaceVariant" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipJoinCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Code: XXXXXX"
                app:chipIcon="@drawable/ic_lock"
                app:chipIconTint="?attr/colorOnSurfaceVariant"
                android:visibility="gone" />

        </com.google.android.material.chip.ChipGroup>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- TabLayout and ViewPager -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:tabMode="fixed"
            app:tabGravity="fill"
            app:tabSelectedTextColor="?attr/colorPrimary"
            app:tabTextColor="?attr/colorOnSurfaceVariant"
            app:tabIndicatorColor="?attr/colorPrimary" />

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>