<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Card View Style -->
    <style name="CardViewStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Button Styles -->
    <style name="ButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
        <item name="iconGravity">textStart</item>
        <item name="iconPadding">8dp</item>
    </style>

    <style name="ButtonStyleOutlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="ButtonStyleText" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">8dp</item>
    </style>

    <!-- Chip Styles -->
    <style name="ChipStyle" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">8dp</item>
    </style>

    <!-- Top App Bar Style -->
    <style name="TopAppBarStyle" parent="Widget.Material3.Toolbar.Surface">
        <item name="android:background">@color/md_theme_surface</item>
        <item name="android:elevation">0dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="BottomNavigationStyle" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/md_theme_surface</item>
        <item name="elevation">8dp</item>
    </style>

</resources>