<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Tisimu" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <!-- <item name="colorPrimary">@color/my_dark_primary</item> -->

        <!-- Primary color for status bar and toolbar -->
        <item name="colorPrimary">@color/md_theme_light_onSurface</item>
        <!-- Text color on primary surfaces (white background) -->
        <item name="colorOnPrimary">@color/md_theme_dark_onPrimary</item>
        <!-- Background color (light grey) -->
        <item name="android:colorBackground">@color/md_theme_dark_background</item>
        <!-- Text color on background -->
        <item name="colorOnBackground">@color/md_theme_dark_onBackground</item>
        <!-- Text color on surfaces (e.g., cards, dialogs) -->
        <item name="colorOnSurface">@color/md_theme_dark_onSurface</item>
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/md_theme_light_onSurface</item>
        <!-- Status bar text color -->
        <item name="android:windowLightStatusBar">true</item>
        <!-- Navigation bar color -->
        <item name="android:navigationBarColor">@color/md_theme_light_onSurface</item>
        <!-- Navigation bar text color -->
        <!--        <item name="android:windowLightNavigationBar">true</item>-->

    </style>
</resources>